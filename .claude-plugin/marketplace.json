{
  "name": "outcomeeng",
  "metadata": {
    "description": "Spec-Driven Engineering for Python and TypeScript"
  },
  "owner": {
    "name": "Simon Heimlicher"
  },
  "plugins": [
    {
      "name": "legacy",
      "source": "./plugins/legacy",
      "description": "Standalone /commit, /handoff, /pickup, /testing, /reviewing-tests for projects without the spx CLI"
    },
    {
      "name": "claude",
      "source": "./plugins/claude",
      "description": "Claude Code meta-skills: /creating-skills"
    },
    {
      "name": "frontend",
      "source": "./plugins/frontend",
      "description": "Frontend design: /designing-frontend skill"
    },
    {
      "name": "typescript",
      "source": "./plugins/typescript",
      "description": "TypeScript engineering: /testing-typescript, /coding-typescript, /reviewing-typescript, /architecting-typescript, /reviewing-typescript-architecture, typescript-simplifier agent"
    },
    {
      "name": "python",
      "source": "./plugins/python",
      "description": "Python engineering: /testing-python, /coding-python, /reviewing-python, /architecting-python, /reviewing-python-architecture"
    },
    {
      "name": "specs",
      "source": "./plugins/specs",
      "description": "Legacy specs/ projects: /managing-specs, /understanding-specs"
    },
    {
      "name": "spx-legacy",
      "source": "./plugins/spx-legacy",
      "description": "Legacy Outcome Engineering (spx/): /writing-prd, /managing-spx, /understanding-spx, /decomposing-*, migration agents"
    },
    {
      "name": "prose",
      "source": "./plugins/prose",
      "description": "Prose craft: /writing-prose (always active), /reviewing-prose (on request)"
    },
    {
      "name": "spec-tree",
      "source": "./plugins/spec-tree",
      "description": "Spec Tree: /understanding, /contextualizing, /bootstrapping, /authoring, /decomposing, /refactoring, /aligning, /testing, /auditing-tests, /coding, /committing-changes, /bootstrap, /author, /commit, /handoff, /pickup, /rtfm, /clarify"
    },
    {
      "name": "visual",
      "source": "./plugins/visual",
      "description": "Visual diagrams: /excalidrawing (Excalidraw JSON generation)"
    },
    {
      "name": "hdl",
      "source": "./plugins/hdl",
      "description": "HDL engineering: /reviewing-vhdl (idiomatic VHDL-2008 review with synthesizability analysis)"
    }
  ]
}
